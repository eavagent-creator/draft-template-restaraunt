rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Hardcoded admin for bootstrapping, plus check in admins collection
      return isSignedIn() && (
        request.auth.token.email == 'edgaragronvargas@gmail.com' && request.auth.token.email_verified == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() <= 100
        && data.customerEmail is string && data.customerEmail.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() <= 20
        && data.type in ['pickup', 'delivery']
        && data.status in ['pending', 'accepted', 'preparing', 'completed', 'cancelled']
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.total is number && data.total >= 0
        && data.createdAt is timestamp
        && (!data.keys().hasAny(['isDelayed']) || data.isDelayed is bool)
        && (!data.keys().hasAny(['delayMinutes']) || data.delayMinutes is number)
        && (!data.keys().hasAny(['estimatedReadyAt']) || data.estimatedReadyAt is timestamp)
        && (!data.keys().hasAny(['paymentMethod']) || data.paymentMethod in ['card', 'cash']);
    }

    // --- Menu Item Validation ---
    function isValidMenuItem(data) {
      return data.name is string && data.name.size() <= 100
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 1000))
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() <= 100
        && data.image is string && data.image.size() <= 1048576 
        && (!data.keys().hasAny(['isAvailable']) || data.isAvailable is bool)
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp);
    }

    // --- Collections ---
    match /menuItems/{itemId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(itemId) && isValidMenuItem(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(incoming()) && (
        incoming().status == 'pending' &&
        incoming().createdAt == request.time
      );
      
      allow get: if true; // Order ID acts as secret

      allow list: if isAdmin() || (
        isSignedIn() && resource.data.customerId == request.auth.uid
      );

      allow update: if isAdmin() && (
        isValidOrder(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'isDelayed', 'estimatedReadyAt', 'delayMinutes']) &&
        incoming().updatedAt == request.time
      );

      allow delete: if false;
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via console
    }
  }
}
